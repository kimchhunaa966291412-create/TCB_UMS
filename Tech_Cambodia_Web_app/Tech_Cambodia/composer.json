{
    "name": "itc/academic-system",
    "description": "ITC Academic Management System — Institute of Technology of Cambodia",
    "type": "project",
    "license": "proprietary",
    "version": "3.1.0",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ITC\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ITC\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
